#!/bin/bash
# Generated by App Service for Linux
cd /home/site/wwwroot

export PORT=${PORT:-8000}
python -m venv /home/site/venv 2>/dev/null
source /home/site/venv/bin/activate
pip install --upgrade pip
pip install -r config/requirements.txt
pip install -r web_app/core/backend/requirements.txt
cd web_app/core/backend
gunicorn --workers 1 --worker-class uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT --timeout 600 main:app
