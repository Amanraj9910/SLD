{
  "test_plan_name": "SLD Processing Platform - Frontend Test Suite",
  "test_scope": "Complete frontend functionality testing",
  "base_url": "http://localhost:3000",
  "test_categories": [
    {
      "category": "Navigation and Layout",
      "tests": [
        {
          "test_id": "NAV_001",
          "test_name": "Main Navigation Functionality",
          "description": "Verify all navigation links work correctly",
          "steps": [
            "Load homepage",
            "Click each navigation item (Home, Component Detection, Real-time YOLOv8x, Text Detection, Annotation Tool, About)",
            "Verify correct page loads for each route",
            "Check active state highlighting"
          ],
          "expected_result": "All navigation links work and show correct pages"
        },
        {
          "test_id": "NAV_002", 
          "test_name": "Responsive Design",
          "description": "Test responsive behavior across different screen sizes",
          "steps": [
            "Test desktop view (1920x1080)",
            "Test tablet view (768x1024)",
            "Test mobile view (375x667)",
            "Verify navigation menu adapts correctly",
            "Check content layout and readability"
          ],
          "expected_result": "Layout adapts properly to all screen sizes"
        }
      ]
    },
    {
      "category": "Component Detection Page",
      "tests": [
        {
          "test_id": "CD_001",
          "test_name": "File Upload Functionality",
          "description": "Test image upload and processing",
          "steps": [
            "Navigate to /component-detection",
            "Upload a valid SLD image file",
            "Verify file is accepted and preview shown",
            "Click 'Detect Components' button",
            "Wait for processing to complete"
          ],
          "expected_result": "File uploads successfully and processing initiates"
        },
        {
          "test_id": "CD_002",
          "test_name": "Detection Results Display",
          "description": "Verify detection results are displayed correctly",
          "steps": [
            "Complete file upload and detection",
            "Check detection results panel appears",
            "Verify bounding boxes are drawn on image",
            "Check component labels and confidence scores",
            "Test export functionality"
          ],
          "expected_result": "Detection results display with proper visualization"
        }
      ]
    },
    {
      "category": "Real-time Detection Page",
      "tests": [
        {
          "test_id": "RT_001",
          "test_name": "Webcam Access and Stream",
          "description": "Test real-time detection interface",
          "steps": [
            "Navigate to /realtime-detection",
            "Grant webcam permissions when prompted",
            "Verify video stream appears",
            "Test start/stop detection toggle",
            "Check real-time overlay functionality"
          ],
          "expected_result": "Webcam stream works with real-time detection overlay"
        }
      ]
    },
    {
      "category": "Text Detection Page", 
      "tests": [
        {
          "test_id": "TD_001",
          "test_name": "Text Extraction Workflow",
          "description": "Test OCR text detection functionality",
          "steps": [
            "Navigate to /text-detection",
            "Upload image with text content",
            "Initiate text detection process",
            "Verify extracted text results",
            "Test export text functionality"
          ],
          "expected_result": "Text is extracted and displayed correctly"
        }
      ]
    },
    {
      "category": "Annotation Tool",
      "tests": [
        {
          "test_id": "AT_001",
          "test_name": "Project Creation",
          "description": "Test creating new annotation project",
          "steps": [
            "Navigate to /annotation-tool",
            "Enter project name",
            "Upload SLD image file",
            "Click 'Create Project'",
            "Verify annotation interface loads"
          ],
          "expected_result": "New annotation project created successfully"
        },
        {
          "test_id": "AT_002",
          "test_name": "Annotation Drawing Tools",
          "description": "Test interactive annotation functionality",
          "steps": [
            "Create or open annotation project",
            "Click 'Add New Box' button",
            "Draw bounding box on image",
            "Select component type from dropdown",
            "Save annotation",
            "Verify annotation appears in list"
          ],
          "expected_result": "Annotations can be created and saved successfully"
        },
        {
          "test_id": "AT_003",
          "test_name": "Gallery Management",
          "description": "Test project gallery functionality",
          "steps": [
            "Create annotation project with annotations",
            "Save project to gallery",
            "Return to gallery view",
            "Verify project appears with thumbnail",
            "Test project reopening from gallery",
            "Test download functionality (Image and JSON)"
          ],
          "expected_result": "Gallery shows projects with proper metadata and download works"
        },
        {
          "test_id": "AT_004",
          "test_name": "Component Type Management",
          "description": "Test adding custom component types",
          "steps": [
            "Open annotation interface",
            "Enter new component name in text field",
            "Click add component button",
            "Verify new component appears in dropdown",
            "Use new component type for annotation",
            "Save and verify persistence"
          ],
          "expected_result": "Custom component types can be added and used"
        },
        {
          "test_id": "AT_005",
          "test_name": "Zoom and Pan Controls",
          "description": "Test canvas zoom and navigation",
          "steps": [
            "Open annotation project",
            "Test zoom in/out buttons",
            "Verify zoom percentage display",
            "Test pan functionality with move tool",
            "Verify annotations scale correctly with zoom"
          ],
          "expected_result": "Zoom and pan work smoothly with proper annotation scaling"
        },
        {
          "test_id": "AT_006",
          "test_name": "Data Export Functionality",
          "description": "Test JSON and image export",
          "steps": [
            "Create project with multiple annotations",
            "Export JSON from annotation interface",
            "Verify JSON structure and content",
            "Download from gallery (both image and JSON)",
            "Verify exported files are correct",
            "Check that image paths are excluded from JSON"
          ],
          "expected_result": "Export functions work correctly with proper data format"
        },
        {
          "test_id": "AT_007",
          "test_name": "Data Persistence",
          "description": "Test localStorage persistence",
          "steps": [
            "Create annotation project",
            "Add several annotations",
            "Save project",
            "Refresh browser page",
            "Verify project still appears in gallery",
            "Reopen project and verify annotations intact"
          ],
          "expected_result": "Projects persist across browser sessions"
        }
      ]
    },
    {
      "category": "Error Handling and Edge Cases",
      "tests": [
        {
          "test_id": "EH_001",
          "test_name": "Invalid File Upload",
          "description": "Test handling of invalid file types",
          "steps": [
            "Try uploading non-image file",
            "Try uploading oversized file",
            "Verify appropriate error messages",
            "Check that UI remains functional"
          ],
          "expected_result": "Invalid uploads are rejected with clear error messages"
        },
        {
          "test_id": "EH_002",
          "test_name": "Network Error Handling",
          "description": "Test behavior when backend is unavailable",
          "steps": [
            "Simulate backend disconnection",
            "Try various operations",
            "Verify error messages appear",
            "Check graceful degradation"
          ],
          "expected_result": "Network errors are handled gracefully with user feedback"
        }
      ]
    },
    {
      "category": "Performance and Usability",
      "tests": [
        {
          "test_id": "PU_001",
          "test_name": "Page Load Performance",
          "description": "Verify acceptable page load times",
          "steps": [
            "Measure initial page load time",
            "Test navigation between pages",
            "Check for loading indicators",
            "Verify smooth transitions"
          ],
          "expected_result": "Pages load within 3 seconds with proper loading states"
        },
        {
          "test_id": "PU_002",
          "test_name": "User Feedback and Notifications",
          "description": "Test toast notifications and user feedback",
          "steps": [
            "Perform various actions (save, export, etc.)",
            "Verify toast notifications appear",
            "Check notification content accuracy",
            "Test notification dismissal"
          ],
          "expected_result": "Users receive clear feedback for all actions"
        }
      ]
    }
  ],
  "test_data": {
    "sample_images": [
      "Valid SLD image (JPG, <5MB)",
      "PNG image with text content",
      "Large image file (>10MB) for error testing",
      "Non-image file for error testing"
    ],
    "test_projects": [
      "Simple project with 1-2 annotations",
      "Complex project with 10+ annotations",
      "Project with custom component types"
    ]
  },
  "success_criteria": {
    "overall_pass_rate": "95%",
    "critical_functionality": "100% (navigation, core features)",
    "performance_requirements": "Page loads <3s, smooth interactions",
    "cross_browser_compatibility": "Chrome, Firefox, Safari, Edge"
  }
}
